{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/upload", "destination": "/api/upload.js" },
    { "source": "/api/cron", "destination": "/api/cron.js" },
    { "source": "/api/facebook-post/(.*)", "destination": "/api/facebook-post.js?postId=$1" },
    { "source": "/api/gmail/(.*)", "destination": "/api/gmail.js?route=$1" },
    { "source": "/api/public/subscribe", "destination": "/api/public-subscribe.js" },
    { "source": "/api/public/verify", "destination": "/api/public-verify.js" },
    { "source": "/api/public/unsubscribe", "destination": "/api/public-unsubscribe.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
